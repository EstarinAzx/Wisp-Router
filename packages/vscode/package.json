{
  "name": "wisp",
  "displayName": "Wisp",
  "description": "BYOK model router for VS Code's Copilot chat, agent, and Ctrl+I — bring your own API keys or ChatGPT (Codex) / Claude.ai subscription. Bridge external tools like Claude Code onto the same providers. Plus Inquire inline edits.",
  "version": "1.7.0",
  "publisher": "EsarinAzx",
  "repository": {
    "type": "git",
    "url": "https://github.com/EstarinAzx/Wisp-Router.git"
  },
  "engines": {
    "vscode": "^1.104.0"
  },
  "categories": [
    "AI",
    "Chat",
    "Machine Learning",
    "Programming Languages"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "languageModelChatProviders": [
      {
        "vendor": "wisp",
        "displayName": "Wisp"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "wisp",
          "title": "Wisp",
          "icon": "media/wisp.svg"
        }
      ]
    },
    "views": {
      "wisp": [
        {
          "id": "wisp.panel",
          "name": "Wisp",
          "type": "webview"
        }
      ]
    },
    "commands": [
      {
        "command": "wisp.setApiKey",
        "title": "Wisp: Set API Key"
      },
      {
        "command": "wisp.listModels",
        "title": "Wisp: List / Choose Model"
      },
      {
        "command": "wisp.inquire",
        "title": "Wisp: Inquire"
      },
      {
        "command": "wisp.codexSignIn",
        "title": "Wisp: Sign in to Codex"
      },
      {
        "command": "wisp.codexSignOut",
        "title": "Wisp: Sign out of Codex"
      },
      {
        "command": "wisp.anthropicSignIn",
        "title": "Wisp: Sign in to Claude"
      },
      {
        "command": "wisp.anthropicSignOut",
        "title": "Wisp: Sign out of Claude"
      },
      {
        "command": "wisp.xaiSignIn",
        "title": "Wisp: Sign in to Grok"
      },
      {
        "command": "wisp.xaiSignOut",
        "title": "Wisp: Sign out of Grok"
      },
      {
        "command": "wisp.bridgeToggle",
        "title": "Wisp: Toggle Bridge"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "wisp.inquire",
          "when": "editorTextFocus",
          "group": "1_modification"
        }
      ]
    },
    "keybindings": [
      {
        "command": "wisp.inquire",
        "key": "ctrl+shift+i",
        "mac": "cmd+shift+i",
        "when": "editorTextFocus"
      }
    ],
    "configuration": {
      "title": "Wisp",
      "properties": {
        "wisp.maxTokens": {
          "type": "number",
          "default": 0,
          "description": "Max tokens per suggestion. 0 = no limit (lets multi-line and reasoning-model completions finish). A positive cap bounds latency but can truncate the answer mid-output."
        },
        "wisp.temperature": {
          "type": "number",
          "default": 0.1,
          "description": "Sampling temperature. Low keeps edits deterministic."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "bun run compile",
    "compile": "tsc -p ./ && tsc -p webview && bun run bundle && vite build",
    "bundle": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --platform=node --format=cjs --sourcemap",
    "watch": "tsc -watch -p ./",
    "build:webview": "vite build",
    "watch:webview": "vite build --watch",
    "package": "vsce package --no-dependencies"
  },
  "dependencies": {
    "@wisp/core": "workspace:*",
    "openai": "^4.80.0"
  },
  "devDependencies": {
    "@preact/preset-vite": "^2.10.0",
    "@tailwindcss/vite": "^4.1.0",
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.104.0",
    "@vscode/vsce": "^3.3.0",
    "esbuild": "^0.25.0",
    "preact": "^10.26.0",
    "tailwindcss": "^4.1.0",
    "typescript": "^7.0.2",
    "vite": "^6.0.0"
  }
}
