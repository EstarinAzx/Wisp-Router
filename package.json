{
  "name": "wisp",
  "displayName": "Wisp",
  "description": "Wisp: AI inline completions and on-demand code generation, backed by the OpenCode Zen provider.",
  "version": "0.0.5",
  "publisher": "local",
  "private": true,
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Machine Learning",
    "Programming Languages"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "wisp",
          "title": "Wisp",
          "icon": "media/wisp.svg"
        }
      ]
    },
    "views": {
      "wisp": [
        {
          "id": "wisp.panel",
          "name": "Wisp",
          "type": "webview"
        }
      ]
    },
    "commands": [
      {
        "command": "wisp.setApiKey",
        "title": "Wisp: Set API Key"
      },
      {
        "command": "wisp.listModels",
        "title": "Wisp: List / Choose Model"
      },
      {
        "command": "wisp.toggle",
        "title": "Wisp: Toggle Autocomplete"
      },
      {
        "command": "wisp.inquire",
        "title": "Wisp: Inquire"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "wisp.inquire",
          "when": "editorHasSelection",
          "group": "1_modification"
        }
      ]
    },
    "configuration": {
      "title": "Wisp",
      "properties": {
        "wisp.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Master on/off switch for inline suggestions."
        },
        "wisp.baseUrl": {
          "type": "string",
          "scope": "machine",
          "default": "https://opencode.ai/zen/go/v1",
          "description": "OpenAI-compatible base URL for the OpenCode Zen provider. Machine-scoped so a workspace cannot redirect requests (and the API key) to another endpoint."
        },
        "wisp.model": {
          "type": "string",
          "default": "minimax-m3",
          "description": "Model id (bare, as served by /models — the endpoint rejects a provider-prefixed id). Run 'Wisp: List / Choose Model' to discover valid ids."
        },
        "wisp.debounceMs": {
          "type": "number",
          "default": 300,
          "description": "Quiet window (ms) after the last keystroke before calling the API."
        },
        "wisp.maxTokens": {
          "type": "number",
          "default": 0,
          "description": "Max tokens per suggestion. 0 = no limit (lets multi-line and reasoning-model completions finish). A positive cap bounds latency but can truncate the answer mid-output."
        },
        "wisp.temperature": {
          "type": "number",
          "default": 0.1,
          "description": "Sampling temperature. Low keeps completions deterministic."
        },
        "wisp.maxPrefixChars": {
          "type": "number",
          "default": 2000,
          "description": "Characters of code before the caret sent as context."
        },
        "wisp.maxSuffixChars": {
          "type": "number",
          "default": 1000,
          "description": "Characters of code after the caret sent as context."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./ && tsc -p webview && vite build",
    "watch": "tsc -watch -p ./",
    "build:webview": "vite build",
    "watch:webview": "vite build --watch"
  },
  "dependencies": {
    "openai": "^4.80.0"
  },
  "devDependencies": {
    "@preact/preset-vite": "^2.10.0",
    "@tailwindcss/vite": "^4.1.0",
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "preact": "^10.26.0",
    "tailwindcss": "^4.1.0",
    "typescript": "^5.4.0",
    "vite": "^6.0.0"
  }
}
